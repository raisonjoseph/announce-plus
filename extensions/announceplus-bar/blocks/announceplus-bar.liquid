{%- assign ap_bars = shop.metafields.announceplus.bars -%}

{%- if ap_bars != blank and ap_bars.value != blank -%}

  <link rel="stylesheet" href="{{ 'announceplus-bar.css' | asset_url }}" />

  {%- for bar in ap_bars.value -%}
    {%- if bar.isEnabled and bar.status == "published" and bar.type != "product_shipping_goal" -%}
      <div
        id="ap-bar-{{ forloop.index }}"
        class="announceplus-bar"
        data-type="{{ bar.type }}"
        data-threshold="{{ bar.thresholdCents | default: 5000 }}"
        data-message="{{ bar.barMessage | escape }}"
        data-success="{{ bar.successMessage | escape }}"
        data-empty-message="{{ bar.emptyMessage | escape }}"
        data-currency="{{ bar.currencySymbol | escape }}"
        data-position="{{ bar.position | default: 'top' }}"
        data-placement="{{ bar.placement | default: 'all_pages' }}"
        data-subtype="{{ bar.announcementSubtype | default: 'simple' }}"
        data-template="{{ template.name | default: '' }}"
        data-show-to="{{ bar.showTo | default: 'all' }}"
        data-device="{{ bar.deviceTarget | default: 'all' }}"
        data-delay="{{ bar.delaySeconds | default: 0 }}"
        data-cart-state="{{ bar.cartState | default: 'any' }}"
        data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
        data-customer-status="{{ bar.customerStatus | default: 'any' }}"
        data-target-urls="{{ bar.targetUrls | escape }}"
        data-exclude-urls="{{ bar.excludeUrls | escape }}"
        data-cart-value-min="{{ bar.cartValueMin | default: 0 }}"
        data-cart-value-max="{{ bar.cartValueMax | default: 0 }}"
        data-cart-item-min="{{ bar.cartItemMin | default: 0 }}"
        data-cart-item-max="{{ bar.cartItemMax | default: 0 }}"
        data-scroll-trigger="{{ bar.scrollTrigger | default: 0 }}"
        data-start-date="{{ bar.startDate | default: '' }}"
        data-end-date="{{ bar.endDate | default: '' }}"
        data-active-days="{{ bar.activeDays | json | escape }}"
        data-customer-tags="{{ customer.tags | join: ',' }}"
        data-required-tags="{{ bar.customerTags | escape }}"
        data-country="{{ localization.country.iso_code | default: '' }}"
        data-country-target="{{ bar.countryTarget | escape }}"
        data-exit-intent="{{ bar.exitIntent | default: false }}"
        data-utm-source="{{ bar.utmSource | escape }}"
        data-utm-medium="{{ bar.utmMedium | escape }}"
        data-utm-campaign="{{ bar.utmCampaign | escape }}"
        data-min-page-views="{{ bar.minPageViews | default: 0 }}"
        data-bar-id="{{ bar.id }}"
        data-app-url="{{ shop.metafields.announceplus.app_url.value | default: '' }}"
        data-rotation-speed="{{ bar.rotationSpeed | default: 15 }}"
        data-marquee-direction="{{ bar.marqueeDirection | default: 'ltr' }}"
        {%- if bar.announcementSubtype == 'rotating' and bar.rotatingMessages -%}
          data-rotating-messages="{{ bar.rotatingMessages | json | escape }}"
          data-rotation-animation="{{ bar.rotationAnimation | default: 'fade' }}"
        {%- endif -%}
        style="
          background-color: {{ bar.backgroundColor | default: '#1a1a1a' }};
          color: {{ bar.textColor | default: '#ffffff' }};
          --ap-bar-color: {{ bar.barColor | default: '#22c55e' }};
          --ap-text-color: {{ bar.textColor | default: '#ffffff' }};
          --ap-font-size: {% case bar.fontSize %}{% when 'small' %}12px{% when 'large' %}16px{% else %}14px{% endcase %};
          --ap-font-weight: {% case bar.fontWeight %}{% when 'medium' %}500{% when 'bold' %}700{% else %}400{% endcase %};
          --ap-text-align: {{ bar.textAlign | default: 'center' }};
        "
      >
        <div class="ap-bar-inner">
          <p class="ap-bar-text">
            {%- if bar.type == 'topbar' -%}
              {{ bar.message }}
            {%- elsif bar.emptyMessage != blank -%}
              {{ bar.emptyMessage }}
            {%- else -%}
              Loading...
            {%- endif -%}
          </p>
          {%- if bar.type == 'shipping_goal' -%}
            <div class="ap-bar-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
              <div class="ap-bar-fill"></div>
            </div>
          {%- endif -%}
          {%- if bar.ctaText != blank -%}
            <a href="{{ bar.ctaUrl }}" class="ap-bar-cta">
              {{ bar.ctaText }}
            </a>
          {%- endif -%}
        </div>
        {%- if bar.showCloseButton != false -%}
          <button class="ap-bar-close" aria-label="Close">&#215;</button>
        {%- endif -%}
      </div>
    {%- endif -%}
  {%- endfor -%}

  <script src="{{ 'announceplus-bar.js' | asset_url }}" defer="defer"></script>

{%- else -%}
  {%- comment -%} No announcements configured — render nothing {%- endcomment -%}
{%- endif -%}

{% schema %}
{
  "name": "AnnouncePlus Bar",
  "target": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "is_enabled",
      "label": "Enable AnnouncePlus",
      "default": true,
      "info": "Master toggle. Announcements are managed in the AnnouncePlus app."
    }
  ]
}
{% endschema %}
